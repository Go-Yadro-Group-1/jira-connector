# connector — per-service environment configuration.
#
# Copy to .env and fill in. Loaded automatically on `serve` via godotenv.
# Values here OVERRIDE the YAML config; secrets live here only, never in
# committed YAML. The config file is optional — on a deploy target that only
# accepts env vars (e.g. Timeweb App Platform) these keys drive the whole config.

# --- Jira ---
JIRA_BASE_URL=https://issues.apache.org/jira
JIRA_TOKEN=             # personal access token (secret); empty = no real sync
JIRA_PROJECT_KEY=DEMO   # used by the `connector run` one-shot sync

# --- Database ---
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres        # secret
DB_PASSWORD=postgres    # secret
DB_NAME=jira_tracker

# --- App ---
LOG_LEVEL=info          # debug | info | warn | error

# --- Diagnostic endpoints ---
METRICS_ADDR=:9090      # Prometheus /metrics
PPROF_ADDR=:6060        # net/http/pprof
