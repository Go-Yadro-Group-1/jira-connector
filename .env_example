# Copy to .env and fill in. Secrets live here, never in committed *.yaml.
# Consumed both by docker-compose interpolation and by the app via os.Getenv.

# --- Jira ---
JIRA_BASE_URL=https://issues.apache.org/jira
JIRA_TOKEN=                 # personal access token (secret)
JIRA_PROJECT_KEY=DEMO       # used by `connector run` one-shot sync

# --- Database (secret credentials) ---
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=jira_connector
